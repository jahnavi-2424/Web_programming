<body>
  <div id="root"></div>

  <script>
    function Welcome(props) {
      return React.createElement(
        "div",
        { style: { textAlign: "center", color: "blue" } },
        [
          React.createElement("h1", null, "Hello, " + props.name),
          React.createElement("h2", null, "Welcome from " + props.city),
          React.createElement("p", null, "This is a React app using props")
        ]
      );
    }

    const root = ReactDOM.createRoot(document.getElementById("root"));
    root.render(React.createElement(Welcome, { name: "John", city: "Chennai" }));
  </script>
</body>

  <title>Image Gallery</title>

  <!-- React CDN -->
  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>

  <!-- Babel -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <style>
    .gallery {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 20px;
    }

    .gallery img {
      width: 100px;
      height: 100px;
      cursor: pointer;
      transition: transform 0.3s;
    }

    .gallery img:hover {
      transform: scale(1.1);
    }

    .preview {
      text-align: center;
      margin-top: 20px;
    }

    .preview img {
      width: 300px;
      height: 300px;
    }
  </style>
</head>

<body>
  <div id="root"></div>

  <script type="text/babel">

    function Gallery() {
      const images = [
        "/Users/jahnaviroyal/Downloads/101-300x300.jpg",
        "/Users/jahnaviroyal/Downloads/102-300x300.jpg",
        "/Users/jahnaviroyal/Downloads/103-300x300.jpg",
        "/Users/jahnaviroyal/Downloads/104-300x300.jpg",
      ];

      const [selectedImage, setSelectedImage] = React.useState(images[0]);

      return (
        <div>
          <h2 style={{textAlign: "center"}}>Image Gallery</h2>

          <div className="preview">
            <img src={selectedImage} alt="Preview" />
          </div>

          <div className="gallery">
            {images.map((img, index) => (
              <img
                key={index}
                src={img}
                onClick={() => setSelectedImage(img)}
              />
            ))}
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById("root"));
    root.render(<Gallery />);

  </script>
</body>
</html>






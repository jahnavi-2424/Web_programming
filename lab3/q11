<!DOCTYPE html>
<html>
<head>
    <title>Simple Interest Calculator</title>
</head>
<body>
    <h2>Simple Interest Calculator</h2>

    <label>Principal Amount:</label>
    <input type="number" id="principal"><br><br>

    <label>Rate of Interest (%):</label>
    <input type="number" id="rate"><br><br>

    <label>Time (years):</label>
    <input type="number" id="time"><br><br>

    <button onclick="calculateSimpleInterest()">Calculate</button>

    <h3 id="output"></h3>

    <script>
        function calculateSI(principal, rate, time) {
            return (principal * rate * time) / 100;
        }

        function calculateSimpleInterest() {
            let principal = parseFloat(document.getElementById("principal").value);
            let rate = parseFloat(document.getElementById("rate").value);
            let time = parseFloat(document.getElementById("time").value);

            let simpleInterest = calculateSI(principal, rate, time);

            document.getElementById("output").innerText =
                "Principal: " + principal +
                ", Rate: " + rate + "%" +
                ", Time: " + time + " years" +
                ", Simple Interest: " + simpleInterest;
        }
    </script>
</body>
</html>


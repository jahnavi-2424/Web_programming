
<!DOCTYPE html>
<html>
<head>
    <title>Job Skills Form</title>
</head>
<body>

<h2>Select Your Skills</h2>

<form id="skillsForm">
    <input type="checkbox" name="skill" value="HTML"> HTML<br>
    <input type="checkbox" name="skill" value="CSS"> CSS<br>
    <input type="checkbox" name="skill" value="JavaScript"> JavaScript<br>
    <input type="checkbox" name="skill" value="Python"> Python<br>
    <input type="checkbox" name="skill" value="Java"> Java<br><br>

    <button type="button" onclick="validateSkills()">Submit</button>
</form>

<p id="result"></p>

<script>
function validateSkills() {
    var form = document.getElementById("skillsForm");

    if (!form.checkValidity()) return;

    var skills = document.getElementsByName("skill");
    var selectedSkills = [];

    for (var i = 0; i < skills.length; i++) {
        if (skills[i].checked) {
            selectedSkills.push(skills[i].value);
        }
    }

    if (selectedSkills.length < 3) {
        document.getElementById("result").innerHTML = "Error: Select at least 3 skills";
    } else {
        document.getElementById("result").innerHTML =
            "Selected Skills: " + selectedSkills.join(", ");
    }
}
</script>

</body>
</html>






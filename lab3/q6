
<!DOCTYPE html>
<html>
<head>
    <title>Student Information System</title>
    <style>
        body { font-family: Arial; margin: 20px; }
        input, select { margin: 5px; padding: 5px; }
        button { margin: 5px; padding: 6px 12px; }
        table { border-collapse: collapse; margin-top: 15px; width: 100%; }
        th, td { border: 1px solid black; padding: 8px; text-align: center; }
        th { background-color: lightgray; }
    </style>
</head>
<body>

<h2>Student Information System</h2>

<form id="studentForm">
    Name: <input type="text" id="studentName"><br>
    Age: <input type="number" id="studentAge"><br>
    Course:
    <select id="studentCourse">
        <option value="CS">CS</option>
        <option value="IT">IT</option>
        <option value="Business">Business</option>
    </select><br>

    <button type="button" onclick="addStudent()">Add Student</button>
    <button type="button" onclick="clearForm()">Reset</button>
</form>

<table id="studentTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Course</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<script>
var studentList = [];

function Student(name, age, course) {
    this.name = name;
    this.age = age;
    this.course = course;

    this.getDetails = function() {
        return this.name + " - " + this.course;
    };
}

function addStudent() {
    var nameValue = document.getElementById("studentName").value;
    var ageValue = document.getElementById("studentAge").value;
    var courseValue = document.getElementById("studentCourse").value;

    if (nameValue === "" || ageValue === "") return;

    var studentObj = new Student(nameValue, ageValue, courseValue);

    studentList.push(studentObj);

    displayStudents();

    document.getElementById("studentForm").reset();
    document.getElementById("studentName").focus();
}

function displayStudents() {
    var tableBody = document.getElementById("studentTable").getElementsByTagName("tbody")[0];
    tableBody.innerHTML = "";

    for (var i = 0; i < studentList.length; i++) {
        var row = "<tr>";
        row += "<td>" + studentList[i].name + "</td>";
        row += "<td>" + studentList[i].age + "</td>";
        row += "<td>" + studentList[i].course + "</td>";
        row += "</tr>";
        tableBody.innerHTML += row;
    }
}

function clearForm() {
    document.getElementById("studentForm").reset();
    document.getElementById("studentName").focus();
}
</script>

</body>
</html>






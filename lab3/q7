
<!DOCTYPE html>
<html>
<head>
    <title>Print 1 to N</title>
</head>
<body>

<h2>Print Numbers from 1 to N</h2>

Enter N: <input type="text" id="inputN">
<button onclick="printNumbers()">Print</button>

<p id="output"></p>

<script>
function printNumbers() {
    var nValue = parseInt(document.getElementById("inputN").value);
    var counter = 1;
    var result = "";

    while (counter <= nValue) {
        result += counter + " ";
        counter++;
    }

    document.getElementById("output").innerHTML = result;
}
</script>

</body>
</html>






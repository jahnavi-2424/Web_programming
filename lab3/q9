
<!DOCTYPE html>
<html>
<head>
    <title>Radio Button Color Selector</title>
</head>
<body>

<h2>Select a Color</h2>

<input type="radio" name="color" value="Red"> Red<br>
<input type="radio" name="color" value="Green"> Green<br>
<input type="radio" name="color" value="Blue"> Blue<br><br>

<button onclick="showSelectedColor()">Show Selected Color</button>

<p id="result"></p>

<script>
function showSelectedColor() {
    var colorOptions = document.getElementsByName("color");
    var selectedValue = "";

    for (var i = 0; i < colorOptions.length; i++) {
        if (colorOptions[i].checked) {
            selectedValue = colorOptions[i].value;
        }
    }

    document.getElementById("result").innerHTML = "Selected Color: " + selectedValue;
}
</script>

</body>
</html>





